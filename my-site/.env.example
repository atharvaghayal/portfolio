# Development Configuration

# Source Maps (set to false in production to reduce bundle size)
GENERATE_SOURCEMAP=false

# EmailJS Configuration
# Get these values from https://www.emailjs.com/
# 
# 1. Service ID: Found in Email Services section
# 2. Template ID: Found in Email Templates section
# 3. Public Key: Found in Account > API Keys section
# 4. Admin Email: The email address that will receive contact form submissions

REACT_APP_EMAILJS_SERVICE_ID=service_your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=template_your_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
REACT_APP_ADMIN_EMAIL=atharva160504@gmail.com
